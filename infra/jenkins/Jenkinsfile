pipeline {
  agent any

  options {
    timestamps()
    skipDefaultCheckout(false)
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    booleanParam(name: 'DEPLOY_PREPROD_K8S', defaultValue: false, description: 'Deploy to local kind preproduction from Jenkins. Requires Docker and kubectl in the controller.')
    booleanParam(name: 'RUN_PREPROD_E2E', defaultValue: false, description: 'Run Playwright against an already running preproduction URL.')
    string(name: 'PREPROD_BASE_URL', defaultValue: 'http://127.0.0.1:18080', description: 'Preproduction URL visible from the Jenkins controller.')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Backend Verify') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from "$HOSTNAME" \
            --user "$(id -u):$(id -g)" \
            --group-add 0 \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -e MAVEN_CONFIG=/tmp/.m2 \
            -e TESTCONTAINERS_RYUK_DISABLED=true \
            -e TESTCONTAINERS_HOST_OVERRIDE=host.docker.internal \
            -w "$PWD/backend" \
            maven:3.9.9-eclipse-temurin-21 \
            sh ./mvnw -B -DskipTests=false verify
        '''
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'backend/target/surefire-reports/*.xml'
        }
      }
    }

    stage('Frontend Quality') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from "$HOSTNAME" \
            --user "$(id -u):$(id -g)" \
            -e npm_config_cache=/tmp/npm-cache \
            -w "$PWD/frontend" \
            node:20-alpine \
            sh -lc "npm ci && npm run lint && npm run test && npm run build"
        '''
      }
    }

    stage('Playwright Local Shell') {
      steps {
        sh '''
          docker run --rm \
            --volumes-from "$HOSTNAME" \
            --user "$(id -u):$(id -g)" \
            -e npm_config_cache=/tmp/npm-cache \
            -w "$PWD/frontend" \
            mcr.microsoft.com/playwright:v1.59.1-noble \
            sh -lc "npm ci && npm run e2e"
        '''
      }
    }

    stage('Docker Compose Config') {
      steps {
        sh '''
          cleanup_env() {
            rm -f .env
          }
          trap cleanup_env EXIT
          ci_secret="$(date +%s)-${BUILD_TAG}"
          cat > .env <<EOF
MYSQL_DATABASE=fiscal_saas_ci
MYSQL_USER=fiscal_saas_ci
MYSQL_PASSWORD=${ci_secret}
MYSQL_ROOT_PASSWORD=${ci_secret}-root
SPRING_DATASOURCE_USERNAME=fiscal_saas_ci
SPRING_DATASOURCE_PASSWORD=${ci_secret}
APP_SECURITY_AUTH_MODE=demo
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://keycloak:8080/realms/fiscal-saas
VITE_LOGIN_MODE=demo
VITE_OIDC_AUTHORITY=http://localhost:18081/realms/fiscal-saas
VITE_OIDC_CLIENT_ID=fiscal-saas-frontend
VITE_OIDC_REDIRECT_URI=http://127.0.0.1:18080
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:18080
VITE_OIDC_SCOPE=openid profile email
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=ci-admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=${ci_secret}-keycloak
EOF
          docker compose -f infra/docker/docker-compose.local.yml config --quiet
          docker compose -f infra/docker/docker-compose.preprod.yml config --quiet
          docker compose -f infra/keycloak/docker-compose.keycloak.yml config --quiet
          docker compose -f infra/observability/docker-compose.observability.yml config --quiet
        '''
      }
    }

    stage('Build Runtime Images') {
      steps {
        sh '''
          docker build -f infra/docker/backend.Dockerfile -t fiscal-saas-backend:ci .
          docker build -f infra/docker/frontend.Dockerfile --build-arg VITE_API_BASE_URL=/api --build-arg VITE_LOGIN_MODE=demo -t fiscal-saas-frontend:ci .
          docker build -f infra/docker/nginx.Dockerfile -t fiscal-saas-nginx:ci .
        '''
      }
    }

    stage('Deploy Kubernetes Preprod') {
      when {
        expression { return params.DEPLOY_PREPROD_K8S }
      }
      steps {
        sh 'pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/k8s-deploy-preprod.ps1'
      }
    }

    stage('Preprod Smoke') {
      when {
        expression { return params.DEPLOY_PREPROD_K8S }
      }
      steps {
        sh 'pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/k8s-smoke-preprod.ps1'
      }
    }

    stage('Preprod Playwright') {
      when {
        expression { return params.RUN_PREPROD_E2E }
      }
      steps {
        sh '''
          docker run --rm \
            --volumes-from "$HOSTNAME" \
            --user "$(id -u):$(id -g)" \
            -e PLAYWRIGHT_BASE_URL="${PREPROD_BASE_URL}" \
            -e npm_config_cache=/tmp/npm-cache \
            -w "$PWD/frontend" \
            mcr.microsoft.com/playwright:v1.59.1-noble \
            sh -lc "npm ci && npm run e2e:preprod"
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts allowEmptyArchive: true, artifacts: 'frontend/playwright-report/**, frontend/test-results/**, backend/target/surefire-reports/**'
      cleanWs(deleteDirs: true, disableDeferredWipeout: true)
    }
  }
}
